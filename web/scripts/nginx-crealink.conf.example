# Nginx 示例配置：将 80 端口转发到 Next.js（3000）
# 用法：
#   1. 复制到 Nginx 配置目录：sudo cp nginx-crealink.conf.example /etc/nginx/conf.d/crealink.conf
#   2. 将下方 your_server_ip 改为服务器公网 IP 或域名（无域名可写 _ 或 default_server）
#   3. 检查配置：sudo nginx -t
#   4. 重载：sudo systemctl reload nginx
# 阿里云 ECS 安全组需放行入方向：80、443（若用 HTTPS）

server {
    listen 80;
    server_name your_server_ip;   # 改为你的公网 IP 或域名，无域名填 _ 或 default_server

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
